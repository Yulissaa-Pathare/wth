data.xml

<?xml version="1.0"?>

<!DOCTYPE students [
<!ELEMENT students (student+)>
<!ELEMENT student (name, marks)>
<!ELEMENT name (#PCDATA)>
<!ELEMENT marks (#PCDATA)>
]>

<?xml-stylesheet type="text/xsl" href="style.xsl"?>

<students>
    <student>
        <name>Rahul</name>
        <marks>80</marks>
    </student>

    <student>
        <name>Anita</name>
        <marks>90</marks>
    </student>
</students>

