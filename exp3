<!DOCTYPE html>
<html>
<head>
<title>Gallery</title>

<style>
.gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
}

img {
    width: 100%;
}

img:hover {
    transform: scale(1.1);
}
</style>

</head>

<body>

<h2>Photo Gallery</h2>

<img id="big" src="img1.jpg" width="200">

<div class="gallery">
    <img src="img1.jpg" onclick="show(this)">
    <img src="img2.jpg" onclick="show(this)">
    <img src="img3.jpg" onclick="show(this)">
</div>

<script>
function show(x) {
    document.getElementById("big").src = x.src;
}
</script>

</body>
</html>
